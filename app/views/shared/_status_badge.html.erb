<%# Status badge partial that handles all status styling %>
<%# Usage: render 'shared/status_badge', status: task.status, size: 'text-xs', additional_classes: 'mt-1' %>
<%
  # Default size if not provided
  size ||= 'text-xs'

  # Determine the color classes based on status name
  color_classes = case status&.name
                  when 'Not Started' then 'bg-gray-100 text-gray-800'
                  when 'In Progress' then 'bg-blue-100 text-blue-800'
                  when 'Ready to Test' then 'bg-purple-100 text-purple-800'
                  when 'Complete', 'Closed' then 'bg-green-100 text-green-800'
                  when 'To Investigate', 'Investigated / Not Started', 'Investigated' then 'bg-orange-100 text-orange-800'
                  else 'bg-gray-100 text-gray-800'
                  end

  # Combine all classes
  all_classes = [size, 'px-2 py-1 rounded-full', color_classes]
  all_classes << additional_classes if defined?(additional_classes)
%>

<span class="<%= all_classes.join(' ') %>">
  <%= status ? t("statuses.#{status.name.parameterize.underscore}", default: status.name) : '' %>
</span>
