<div class="container mx-auto px-4 py-8 max-w-2xl">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('views.task_categories.index.title') %></h1>
    <%= link_to t('views.task_categories.index.new_category'), new_task_category_path, class: 'bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded' %>
  </div>

  <div class="mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-2"><%= t('views.task_categories.index.defaults_title') %></h2>
    <p class="text-sm text-gray-500 mb-3"><%= t('views.task_categories.index.defaults_help') %></p>
    <div class="surface shadow rounded-lg divide-y divide-gray-200">
      <% @default_categories.each do |category| %>
        <div class="px-4 py-3 flex items-center justify-between">
          <%= render 'shared/category_badge', task_category: category, size: 'text-sm' %>
          <%= link_to edit_task_category_path(category), class: "text-blue-600 hover:text-blue-800" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <h2 class="text-lg font-semibold text-gray-900 mb-2"><%= t('views.task_categories.index.custom_title') %></h2>
    <% if @custom_categories.empty? %>
      <p class="text-sm text-gray-500"><%= t('views.task_categories.index.no_custom_categories') %></p>
    <% else %>
      <div class="surface shadow rounded-lg divide-y divide-gray-200">
        <% @custom_categories.each do |category| %>
          <div class="px-4 py-3 flex items-center justify-between">
            <%= render 'shared/category_badge', task_category: category, size: 'text-sm' %>
            <div class="flex space-x-2">
              <%= link_to edit_task_category_path(category), class: "text-blue-600 hover:text-blue-800" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
              <% end %>
              <%= button_to task_category_path(category), method: :delete, class: "text-red-600 hover:text-red-800", data: { confirm: t('views.task_categories.index.delete_confirm') } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
