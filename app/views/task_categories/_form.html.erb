<%= form_with(model: task_category, class: "space-y-6") do |f| %>
  <% if task_category.errors.any? %>
    <div class="bg-red-50 p-4 rounded-lg">
      <div class="text-red-700 font-medium">
        <%= pluralize(task_category.errors.count, t('views.task_categories.form.error'), t('views.task_categories.form.errors')) %> <%= t('views.task_categories.form.prohibited_save') %>
      </div>
      <ul class="list-disc list-inside text-red-600">
        <% task_category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if task_category.default? %>
    <div>
      <h2 class="text-sm font-medium text-gray-500"><%= t('views.task_categories.form.name') %></h2>
      <p class="mt-1 text-gray-900"><%= task_category.display_name %></p>
      <p class="mt-1 text-sm text-gray-500"><%= t('views.task_categories.form.default_name_help') %></p>
    </div>
  <% else %>
    <div>
      <%= f.label :name, t('views.task_categories.form.name'), class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
  <% end %>

  <div>
    <%= f.label :color, t('views.task_categories.form.color_label'), class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1 flex flex-wrap gap-2">
      <% TaskCategory::COLORS.each do |color_option| %>
        <label class="flex items-center space-x-2 cursor-pointer">
          <%= f.radio_button :color, color_option, class: "sr-only" %>
          <div class="w-8 h-8 rounded-full border-2 <%= color_option == task_category.color ? 'border-gray-900' : 'border-gray-300' %>
                      <%= case color_option
                          when 'red' then 'bg-red-500'
                          when 'orange' then 'bg-orange-500'
                          when 'yellow' then 'bg-yellow-500'
                          when 'green' then 'bg-green-500'
                          when 'blue' then 'bg-blue-500'
                          when 'purple' then 'bg-purple-500'
                          when 'pink' then 'bg-pink-500'
                          when 'gray' then 'bg-gray-500'
                          end %>">
          </div>
          <span class="text-sm text-gray-700"><%= t("views.task_categories.form.colors.#{color_option}") %></span>
        </label>
      <% end %>
      <label class="flex items-center space-x-2 cursor-pointer">
        <%= f.radio_button :color, '', class: "sr-only" %>
        <div class="w-8 h-8 rounded-full border-2 <%= task_category.color.blank? ? 'border-gray-900' : 'border-gray-300' %> bg-white">
        </div>
        <span class="text-sm text-gray-700"><%= t('views.task_categories.form.colors.none') %></span>
      </label>
    </div>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to t('views.task_categories.form.cancel'), task_categories_path, class: "px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    <%= f.submit t('views.task_categories.form.submit'), class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
<% end %>
