<div id="task-result-modal" class="fixed inset-0 z-50 hidden" aria-hidden="true">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-[1px]" data-task-result-modal-close="overlay"></div>

  <div class="relative z-10 flex min-h-full items-center justify-center p-4">
    <div class="task-result-modal-panel surface w-full max-w-md rounded-xl shadow-lg p-5 border">
      <h2 class="text-xl font-semibold text-gray-900 mb-1.5 leading-tight"><%= t("views.tasks.result_modal.title") %></h2>
      <p class="text-sm text-gray-600 mb-3"><%= t("views.tasks.result_modal.description") %></p>

      <div id="task-result-modal-context" class="task-result-modal-context border-b border-gray-200 pb-3 mb-3 hidden">
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-0.5"><%= t("views.tasks.result_modal.context_task_label") %></p>
        <p id="task-result-modal-task-title" class="text-lg font-semibold text-gray-900 leading-snug"></p>
        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 mt-2 mb-0.5"><%= t("views.tasks.result_modal.context_project_label") %></p>
        <p id="task-result-modal-project-name" class="text-sm font-medium text-gray-700"></p>
      </div>

      <div class="space-y-3">
        <div>
          <label for="task-result-value" class="block text-sm font-medium text-gray-700 mb-1">
            <%= t("views.tasks.result_modal.result_label") %>
          </label>
          <select id="task-result-value" class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            <option value="complete"><%= t("task_results.values.complete") %></option>
            <option value="incomplete"><%= t("task_results.values.incomplete") %></option>
          </select>
        </div>

        <div id="task-result-reason-group" class="hidden">
          <label for="task-result-reason" class="block text-sm font-medium text-gray-700 mb-1">
            <%= t("views.tasks.result_modal.reason_label") %>
          </label>
          <input
            id="task-result-reason"
            type="text"
            class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
            placeholder="<%= t("views.tasks.result_modal.reason_placeholder") %>"
          />
          <div id="task-result-reason-suggestions" class="mt-2 flex flex-wrap gap-2">
            <% TaskResult::REASON_SUGGESTION_KEYS.each do |reason_key| %>
              <button
                type="button"
                class="task-result-suggestion-chip px-2.5 py-1 rounded-full text-xs border border-gray-300 text-gray-700 hover:bg-gray-100"
                data-task-result-suggestion="<%= t("task_results.reason_suggestions.#{reason_key}") %>"
              >
                <%= t("task_results.reason_suggestions.#{reason_key}") %>
              </button>
            <% end %>
          </div>
          <p class="mt-1 text-xs text-gray-500"><%= t("views.tasks.result_modal.reason_help") %></p>
        </div>
      </div>

      <div class="mt-4 flex justify-end gap-2">
        <button type="button" data-task-result-modal-close="button" class="task-result-secondary-btn px-3 py-2 text-sm">
          <%= t("views.tasks.result_modal.cancel") %>
        </button>
        <button type="button" id="task-result-confirm" class="task-result-primary-btn px-3 py-2 text-sm">
          <%= t("views.tasks.result_modal.confirm") %>
        </button>
      </div>
    </div>
  </div>
</div>
