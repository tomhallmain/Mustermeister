<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('views.tasks.index.title') %></h1>
    <div class="flex items-center space-x-4">
      <div class="relative group">
        <%= link_to '#', class: 'bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded shadow-md flex items-center' do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          <%= t('views.tasks.index.new_task') %>
        <% end %>
        <div class="absolute right-0 top-full w-64 surface rounded-lg shadow-lg py-2 hidden group-hover:block z-10">
          <div class="px-4 py-2 text-sm text-gray-700 border-b border-gray-200"><%= t('views.tasks.index.select_project') %></div>
          <% current_user.projects.ordered_by_last_task_update.each do |project| %>
            <%= link_to project.title, new_project_task_path(project, show_completed: params[:show_completed]), 
                class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
          <% end %>
        </div>
      </div>
      <% if @last_created_task %>
        <%= link_to new_project_task_path(@last_created_task.project, source_task_id: @last_created_task.id, show_completed: params[:show_completed]),
            class: 'flex items-center space-x-2 px-4 py-2 rounded-md bg-gray-100 text-gray-700 hover:bg-opacity-80' do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          <span><%= t('views.tasks.index.duplicate_last_task') %></span>
        <% end %>
      <% end %>
      <%= link_to params[:show_completed] == 'true' ? tasks_path(show_completed: false, sort_by: @sort_by, search: @search) : tasks_path(show_completed: true, sort_by: @sort_by, search: @search),
          class: "flex items-center space-x-2 px-4 py-2 rounded-md #{params[:show_completed] == 'true' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-700'} hover:bg-opacity-80",
          data: { turbo: false } do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
        </svg>
        <span><%= params[:show_completed] == 'true' ? t('views.tasks.index.hide_completed') : t('views.tasks.index.show_completed') %></span>
      <% end %>
      <%= link_to task_categories_path,
          class: "flex items-center space-x-2 px-4 py-2 rounded-md bg-gray-100 text-gray-700 hover:bg-opacity-80" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
        </svg>
        <span><%= t('views.tasks.index.manage_categories') %></span>
      <% end %>
    </div>
  </div>

  <%= form_with url: tasks_path, method: :get, class: "mb-6", data: { turbo: false } do |f| %>
    <div class="flex gap-4 items-center">
      <div class="flex-grow">
        <%= f.text_field :search,
            placeholder: t('views.tasks.index.search_placeholder'),
            value: @search,
            class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>
      <%= f.label :sort_by, t('views.tasks.index.sort_by'), class: "text-sm font-medium text-gray-700 whitespace-nowrap" %>
      <%= f.select :sort_by,
          [
            [t('views.tasks.index.sort.updated_desc'), 'updated_desc'],
            [t('views.tasks.index.sort.active_oldest_completed_newest'), 'active_oldest_completed_newest']
          ],
          { selected: @sort_by },
          { class: "px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500", onchange: "this.form.requestSubmit()" } %>
      <%= f.hidden_field :show_completed, value: params[:show_completed] %>
      <%= f.submit t('views.tasks.index.search'), class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
      <% if @search.present? %>
        <%= link_to t('views.tasks.index.clear'), tasks_path(show_completed: params[:show_completed], sort_by: @sort_by, search: ''), class: "bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
      <% end %>
    </div>
  <% end %>

  <div class="surface shadow-lg rounded-lg">
    <% @tasks.each do |task| %>
      <div class="task-item border-b border-gray-200 p-3 flex items-center justify-between hover:bg-gray-50 <%= task.project&.color_classes %>" style="background-color: var(--color-surface-elevated);">
        <div class="flex items-center space-x-3">
          <%= button_to toggle_task_path(task, show_completed: params[:show_completed]), method: :patch, class: "flex-shrink-0", form: { data: { task_completed: task.completed.to_s, task_title: task.title, project_name: task.project&.title } } do %>
            <div class="w-5 h-5 border-2 rounded <%= task.completed ? 'bg-green-500 border-green-500' : 'border-gray-400' %>">
              <% if task.completed %>
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              <% end %>
            </div>
          <% end %>
          
          <div class="flex-grow min-w-0">
            <h3 class="text-sm font-semibold <%= task.completed ? 'line-through text-gray-500' : 'text-gray-900' %>">
              <%= link_to task.title, task_path(task), class: "hover:text-blue-600" %>
            </h3>
            <div class="text-xs text-gray-600 prose prose-sm max-w-none"><%= markdown_robust(task.description) %></div>
            <div class="flex flex-wrap gap-2 mt-1">
              <% if task.project %>
                <span class="text-xs text-gray-500">
                  <%= t('views.tasks.index.project_label') %> <%= link_to task.project.title, project_path(task.project), class: "text-blue-600 hover:text-blue-800" %>
                </span>
              <% end %>
              <% if task.due_date %>
                <span class="text-xs text-gray-500">
                  <%= t('views.tasks.index.due_label') %>: <%= task.due_date.strftime("%b %d, %Y") %>
                </span>
              <% end %>
              <%= render 'shared/priority_badge', priority: task.priority %>
              <%= render 'shared/category_badge', task_category: task.task_category %>
              <%= render 'shared/status_badge', status: task.status %>
              <div class="text-xs text-gray-500">
                <%= t('views.tasks.index.created_label') %>: <%= task.created_at.strftime("%b %d, %Y") %>
                <% if task.updated_at != task.created_at %>
                  <br><%= t('views.tasks.index.updated_label') %>: <%= task.updated_at.strftime("%b %d, %Y") %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
        
        <div class="flex space-x-2">
          <%= link_to edit_task_path(task), class: "text-blue-600 hover:text-blue-800" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
          <% end %>

          <%= link_to new_project_task_path(task.project, source_task_id: task.id, show_completed: params[:show_completed]),
              class: "text-indigo-600 hover:text-indigo-800", title: t('views.tasks.index.duplicate_task') do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          <% end %>

          <%= button_to archive_task_path(task, show_completed: params[:show_completed]), method: :post, class: "text-gray-600 hover:text-gray-800",
              data: { confirm: t('views.tasks.index.archive_confirm') } do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
            </svg>
          <% end %>
          
          <%= button_to task_path(task, show_completed: params[:show_completed]), method: :delete, class: "text-red-600 hover:text-red-800", 
              data: { confirm: t('views.tasks.index.delete_confirm') } do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="mt-8">
    <%= paginate @tasks, window: 2, outer_window: 1, views_prefix: 'shared', data: { turbo: false } %>
  </div>
</div>

<style>
  /* Smooth color transitions for task items */
  .task-item {
    transition: all 0.3s ease-in-out;
  }

  /* Enhanced color styling for task items */
  .border-l-4 {
    border-left-width: 4px;
  }

  /* Subtle color tinting for better visual hierarchy */
  .bg-red-50 { background-color: rgba(254, 242, 242, 0.8); }
  .bg-orange-50 { background-color: rgba(255, 247, 237, 0.8); }
  .bg-yellow-50 { background-color: rgba(254, 249, 195, 0.8); }
  .bg-green-50 { background-color: rgba(240, 253, 244, 0.8); }
  .bg-blue-50 { background-color: rgba(239, 246, 255, 0.8); }
  .bg-purple-50 { background-color: rgba(250, 245, 255, 0.8); }
  .bg-pink-50 { background-color: rgba(253, 242, 248, 0.8); }
  .bg-gray-50 { background-color: rgba(249, 250, 251, 0.8); }
</style> 