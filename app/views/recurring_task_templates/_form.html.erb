<%= form_with(model: recurring_task_template, class: "space-y-6") do |f| %>
  <% if recurring_task_template.errors.any? %>
    <div class="bg-red-50 p-4 rounded-lg">
      <div class="text-red-700 font-medium">
        <%= pluralize(recurring_task_template.errors.count, t('views.recurring_task_templates.form.error'), t('views.recurring_task_templates.form.errors')) %> <%= t('views.recurring_task_templates.form.prohibited_save') %>
      </div>
      <ul class="list-disc list-inside text-red-600">
        <% recurring_task_template.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= f.label :title, t('views.recurring_task_templates.form.title'), class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :description, t('views.recurring_task_templates.form.description'), class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :description, rows: 3,
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :project_id, t('views.recurring_task_templates.form.project'), class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :project_id, @projects, :id, :title,
          { prompt: t('views.recurring_task_templates.form.select_project') },
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :base_unit, t('views.recurring_task_templates.form.repeat'), class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1 flex items-center gap-2">
        <span class="text-sm text-gray-500"><%= t('views.recurring_task_templates.form.every') %></span>
        <%= f.number_field :interval, min: 0.5, step: 0.5,
            class: "block w-20 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
        <%= f.select :base_unit,
            RecurringTaskTemplate::BASE_UNITS.map { |unit| [t("views.recurring_task_templates.form.base_units.#{unit}"), unit] },
            {},
            class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <p class="mt-1 text-sm text-gray-500"><%= t('views.recurring_task_templates.form.interval_help') %></p>
    </div>

    <div>
      <%= f.label :start_date, t('views.recurring_task_templates.form.start_date'), class: "block text-sm font-medium text-gray-700" %>
      <%= f.date_field :start_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      <p class="mt-1 text-sm text-gray-500"><%= t('views.recurring_task_templates.form.start_date_help') %></p>
    </div>

    <div>
      <%= f.label :priority, t('views.recurring_task_templates.form.priority'), class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :priority,
          [[t('priorities.leisure'), 'leisure'], [t('priorities.low'), 'low'], [t('priorities.medium'), 'medium'], [t('priorities.high'), 'high']],
          {},
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :task_category_id, t('views.recurring_task_templates.form.category'), class: "block text-sm font-medium text-gray-700" %>
      <%
        category_options = @task_categories.map { |c| [c.display_name, c.id] }
      %>
      <%= f.select :task_category_id,
          options_for_select(category_options, recurring_task_template.task_category_id),
          { include_blank: t('views.recurring_task_templates.form.select_category') },
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div class="flex items-center">
      <%= f.check_box :active, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
      <%= f.label :active, t('views.recurring_task_templates.form.active'), class: "ml-2 block text-sm text-gray-900" %>
    </div>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to t('views.recurring_task_templates.form.cancel'), recurring_task_templates_path,
        class: "px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
    <%= f.submit t('views.recurring_task_templates.form.submit'), class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
<% end %>
