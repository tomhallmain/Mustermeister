<div class="container mx-auto px-4 py-8 max-w-5xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("application.navigation.task_insights", default: "Task Insights") %></h1>
    <p class="text-sm text-gray-600 mt-1">Ask questions about your current tasks to surface patterns and risks.</p>
  </div>

  <div class="surface shadow-lg rounded-lg p-6">
    <%= form_with url: task_insights_path, method: :post, data: { turbo: false }, class: "space-y-4", id: "task-insights-form", html: { novalidate: true } do %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="ai_locale" class="block text-sm font-medium text-gray-700 mb-1"><%= t('views.reports.analysis.ai_locale_label', default: 'AI language') %></label>
          <select id="ai_locale" name="ai_locale" class="w-full rounded-md border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500">
            <% @available_ai_locales.each do |locale_code| %>
              <option value="<%= locale_code %>" <%= "selected" if locale_code == @ai_locale %>><%= locale_code %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label for="ai_model" class="block text-sm font-medium text-gray-700 mb-1"><%= t('views.reports.analysis.ai_model_label', default: 'Model') %></label>
          <select id="ai_model" name="ai_model" class="w-full rounded-md border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500">
            <% @available_ai_models.each do |model_name| %>
              <option value="<%= model_name %>" <%= "selected" if model_name == @ai_model %>><%= model_name %></option>
            <% end %>
          </select>
        </div>
      </div>

      <% if @available_ai_models.empty? %>
        <p class="text-sm text-amber-700"><%= t('views.reports.analysis.ai_no_local_models', default: 'No local Ollama models found') %></p>
      <% end %>

      <div>
        <label for="question" class="block text-sm font-medium text-gray-700 mb-1">Your question</label>
        <textarea id="question" name="question" rows="5" class="w-full rounded-md border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500" placeholder="Example: What patterns do you see in high-priority open tasks?"><%= @question %></textarea>
      </div>

      <div>
        <button type="submit" id="task-insights-submit" class="bg-indigo-600 hover:bg-indigo-800 text-white font-bold py-2 px-4 rounded" <%= "disabled" if @available_ai_models.empty? %>>
          Ask Insights
        </button>
      </div>
    <% end %>
  </div>

  <div id="task-insights-live-status" class="hidden surface shadow-lg rounded-lg p-4 mt-4 border border-indigo-200">
    <h2 class="text-sm font-semibold text-gray-900 mb-1">Agent status</h2>
    <div class="flex items-center gap-2 text-sm text-gray-600">
      <span class="inline-block h-4 w-4 rounded-full border-2 border-indigo-600 border-t-transparent animate-spin" id="task-insights-live-spinner" aria-hidden="true"></span>
      <span id="task-insights-live-status-text">Starting…</span>
    </div>
    <p id="task-insights-live-error" class="hidden mt-2 text-sm text-red-700"></p>
  </div>

  <div id="task-insights-result" class="mt-6"></div>
</div>

<script>
  (function() {
    var form = document.getElementById('task-insights-form');
    var submit = document.getElementById('task-insights-submit');
    var liveBox = document.getElementById('task-insights-live-status');
    var liveText = document.getElementById('task-insights-live-status-text');
    var liveError = document.getElementById('task-insights-live-error');
    var spinner = document.getElementById('task-insights-live-spinner');
    var resultEl = document.getElementById('task-insights-result');
    var pollTimer = null;

    if (!form || !liveBox || !liveText || !resultEl) return;

    var createUrl = <%= raw task_insights_path.to_json %>;
    var statusUrlTemplate = <%= raw task_insights_status_path(run_id: "__RUN_ID__").to_json %>;
    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    csrfToken = csrfToken ? csrfToken.getAttribute('content') : '';

    var STATE_LABELS = {
      received_question: 'Processing your question…',
      requesting_model_step: 'Querying model for next step…',
      model_response_invalid: 'Evaluating model response…',
      attempting_json_repair: 'Repairing invalid model output…',
      model_response_unrecoverable: 'Could not parse model output',
      model_request_failed: 'Model request failed',
      executing_tool: 'Running a tool…',
      tool_result_received: 'Tool finished; continuing…',
      final_answer_ready: 'Composing final answer…',
      fallback_answer: 'Finishing up…',
      final_answer_empty: 'Finishing up…',
      job_exception: 'Error'
    };

    function clearPoll() {
      if (pollTimer) {
        window.clearInterval(pollTimer);
        pollTimer = null;
      }
    }

    function resetSubmitUi() {
      if (!submit) return;
      submit.disabled = false;
      submit.classList.remove('opacity-70', 'cursor-not-allowed');
    }

    function setSpinner(active) {
      if (!spinner) return;
      spinner.classList.toggle('hidden', !active);
    }

    function labelForPayload(payload) {
      var events = payload.state_events || [];
      if (!events.length) return 'Waiting for the job to start…';
      var last = events[events.length - 1];
      var key = last.state;
      var modelCalls = events.filter(function(e) { return e.state === 'requesting_model_step'; }).length;
      var toolCalls = events.filter(function(e) { return e.state === 'executing_tool'; }).length;
      if (key === 'requesting_model_step') return 'Querying model for next step (model call ' + modelCalls + ')…';
      if (key === 'executing_tool' && last.tool) return 'Running tool #' + toolCalls + ': ' + displayToolName(last.tool);
      if (key === 'tool_result_received' && last.tool) {
        var count = (typeof last.result_count === 'number') ? ('; returned ' + last.result_count + ' item(s)') : '';
        return 'Tool #' + toolCalls + ' finished: ' + displayToolName(last.tool) + count;
      }
      if (STATE_LABELS[key]) return STATE_LABELS[key];
      return key || 'Working…';
    }

    function esc(s) {
      var d = document.createElement('div');
      d.textContent = s == null ? '' : String(s);
      return d.innerHTML;
    }

    function displayToolName(tool) {
      if (typeof tool === 'string') return tool;
      try {
        return JSON.stringify(tool);
      } catch (_e) {
        return String(tool);
      }
    }

    function renderResult(payload) {
      var answer = payload.answer || '';
      var tools = payload.tool_calls || [];
      var events = payload.state_events || [];
      var html = '<div class="surface shadow-lg rounded-lg p-6 border border-indigo-200">';
      html += '<h2 class="text-lg font-semibold text-gray-900 mb-2">Answer</h2>';
      html += '<p class="text-sm text-gray-700 whitespace-pre-line">' + esc(answer) + '</p>';
      if (tools.length) {
        html += '<div class="mt-4"><h3 class="text-sm font-semibold text-gray-700 mb-1">Tools used</h3><ul class="text-xs text-gray-600 space-y-1">';
        for (var t = 0; t < tools.length; t++) {
          var c = tools[t];
          var args = esc(JSON.stringify(c.arguments || {}));
          var countText = (typeof c.result_count === 'number') ? ' → returned ' + c.result_count + ' item(s)' : '';
          var errorText = c.error ? ' — error: ' + c.error : '';
          html += '<li><code>' + esc(displayToolName(c.tool)) + '</code> ' + args + esc(countText + errorText) + '</li>';
        }
        html += '</ul></div>';
      }
      if (events.length) {
        html += '<div class="mt-4"><h3 class="text-sm font-semibold text-gray-700 mb-1">Agent state trace</h3><ul class="text-xs text-gray-600 space-y-1">';
        for (var e = 0; e < events.length; e++) {
          var ev = events[e];
          var line = esc(ev.state || '');
          if (ev.tool) line += ' (' + esc(displayToolName(ev.tool)) + ')';
          if (typeof ev.result_count === 'number') line += ' — returned ' + esc(ev.result_count) + ' item(s)';
          if (ev.error) line += ' — error: ' + esc(ev.error);
          if (ev.message) line += ' — ' + esc(ev.message);
          html += '<li>' + line + '</li>';
        }
        html += '</ul></div>';
      }
      html += '</div>';
      resultEl.innerHTML = html;
    }

    function pollStatus(runId) {
      var url = statusUrlTemplate.replace('__RUN_ID__', encodeURIComponent(runId));
      var attempts = 0;
      var maxAttempts = 900;

      clearPoll();

      function pollOnce() {
        attempts += 1;
        if (attempts > maxAttempts) {
          clearPoll();
          liveError.textContent = 'Timed out waiting for the server. If you use production Solid Queue, ensure a worker is running.';
          liveError.classList.remove('hidden');
          setSpinner(false);
          resetSubmitUi();
          return;
        }

        fetch(url, {
          method: 'GET',
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin'
        }).then(function(r) {
          if (r.status === 404) throw new Error('Run not found or expired.');
          if (!r.ok) throw new Error('Status request failed (' + r.status + ').');
          return r.json();
        }).then(function(payload) {
          liveText.textContent = labelForPayload(payload);
          if (payload.status === 'complete') {
            clearPoll();
            liveBox.classList.add('hidden');
            liveError.classList.add('hidden');
            setSpinner(false);
            resetSubmitUi();
            renderResult(payload);
          } else if (payload.status === 'failed') {
            clearPoll();
            liveText.textContent = 'Failed';
            liveError.textContent = payload.error || 'Something went wrong.';
            liveError.classList.remove('hidden');
            setSpinner(false);
            resetSubmitUi();
            renderResult(payload);
            liveBox.classList.remove('hidden');
          }
        }).catch(function(err) {
          clearPoll();
          liveText.textContent = 'Error';
          liveError.textContent = err.message || String(err);
          liveError.classList.remove('hidden');
          setSpinner(false);
          resetSubmitUi();
        });
      }

      pollOnce();
      pollTimer = window.setInterval(pollOnce, 400);
    }

    form.addEventListener('submit', function(ev) {
      ev.preventDefault();
      clearPoll();

      var question = (document.getElementById('question') || {}).value || '';
      if (!question.trim()) return;

      liveBox.classList.remove('hidden');
      liveError.classList.add('hidden');
      liveError.textContent = '';
      liveText.textContent = 'Sending request…';
      setSpinner(true);
      resultEl.innerHTML = '';

      if (submit) {
        submit.disabled = true;
        submit.classList.add('opacity-70', 'cursor-not-allowed');
      }

      var aiLocale = (document.getElementById('ai_locale') || {}).value;
      var aiModel = (document.getElementById('ai_model') || {}).value;

      fetch(createUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        credentials: 'same-origin',
        body: JSON.stringify({
          question: question,
          ai_locale: aiLocale,
          ai_model: aiModel
        })
      }).then(function(r) {
        return r.json().then(function(body) {
          return { ok: r.ok, status: r.status, body: body };
        });
      }).then(function(res) {
        if (!res.ok) {
          var msg = (res.body && res.body.error) ? res.body.error : ('Request failed (' + res.status + ')');
          throw new Error(msg);
        }
        if (!res.body.run_id) throw new Error('No run id returned.');
        liveText.textContent = 'Run started; waiting for updates…';
        pollStatus(res.body.run_id);
      }).catch(function(err) {
        liveText.textContent = 'Could not start run';
        liveError.textContent = err.message || String(err);
        liveError.classList.remove('hidden');
        setSpinner(false);
        resetSubmitUi();
      });
    });

    window.addEventListener('pageshow', function() {
      clearPoll();
      resetSubmitUi();
    });

    window.addEventListener('pagehide', clearPoll);
  })();
</script>
