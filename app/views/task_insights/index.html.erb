<div class="container mx-auto px-4 py-8 max-w-5xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t("application.navigation.task_insights", default: "Task Insights") %></h1>
    <p class="text-sm text-gray-600 mt-1">Ask questions about your current tasks to surface patterns and risks.</p>
  </div>

  <div class="surface shadow-lg rounded-lg p-4 mb-6">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-900">Recent Chats</h2>
      <%= link_to "New chat", task_insights_path, class: "text-sm text-indigo-700 hover:text-indigo-900 font-medium" %>
    </div>
    <% if @conversations.present? %>
      <ul class="list-none p-0 m-0 divide-y divide-gray-200">
        <% @conversations.each do |conversation| %>
          <li class="py-2">
            <%= link_to conversation.title, task_insights_path(conversation_id: conversation.id), class: "text-sm #{conversation.id == @active_conversation&.id ? 'text-indigo-700 font-semibold' : 'text-gray-700 hover:text-indigo-700'}" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500 italic">No conversations yet. Start by asking your first question.</p>
    <% end %>
  </div>

  <div class="surface shadow-lg rounded-lg p-6">
    <%= form_with url: task_insights_path, method: :post, data: { turbo: false }, class: "space-y-4", id: "task-insights-form", html: { novalidate: true } do %>
      <%= hidden_field_tag :conversation_id, @active_conversation&.id, id: "conversation_id" %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="ai_locale" class="block text-sm font-medium text-gray-700 mb-1"><%= t('views.reports.analysis.ai_locale_label', default: 'AI language') %></label>
          <select id="ai_locale" name="ai_locale" class="w-full rounded-md border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500">
            <% @available_ai_locales.each do |locale_code| %>
              <option value="<%= locale_code %>" <%= "selected" if locale_code == @ai_locale %>><%= locale_code %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label for="ai_model" class="block text-sm font-medium text-gray-700 mb-1"><%= t('views.reports.analysis.ai_model_label', default: 'Model') %></label>
          <select id="ai_model" name="ai_model" class="w-full rounded-md border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500">
            <% @available_ai_models.each do |model_name| %>
              <option value="<%= model_name %>" <%= "selected" if model_name == @ai_model %>><%= model_name %></option>
            <% end %>
          </select>
        </div>
      </div>

      <p id="task-insights-ollama-msg" class="text-sm text-amber-700 <%= 'hidden' if @available_ai_models.any? %>" role="status">
        <%= t('views.reports.analysis.ai_no_local_models', default: 'No local Ollama models found') %>
      </p>

      <div>
        <h2 class="text-sm font-medium text-gray-700 mb-1">Exclude Projects From AI Context</h2>
        <p class="text-xs text-gray-500 mb-2">Excluded projects are never sent to AI tools or included in stats/results.</p>
        <div class="mb-2">
          <input type="text" id="excluded-project-search" placeholder="Search projects to exclude..." class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" autocomplete="off">
        </div>
        <div class="mb-2">
          <button type="button" id="toggle-all-excluded-projects" class="text-sm text-blue-600 hover:text-blue-800">Select all</button>
        </div>
        <ul id="excluded-projects-list" class="max-h-56 border border-gray-200 rounded-md surface overflow-y-auto list-none p-0 m-0 divide-y divide-gray-200">
          <% if @available_projects.empty? %>
            <li class="px-3 py-3 text-gray-500 italic">No projects available</li>
          <% else %>
            <% @available_projects.each do |project| %>
              <li class="excluded-project-row" data-project-title="<%= project.title %>">
                <label class="flex items-center gap-3 w-full cursor-pointer py-2.5 px-3 hover:bg-gray-50 text-left">
                  <input type="checkbox" name="excluded_project_ids[]" value="<%= project.id %>" <%= "checked" if @excluded_project_ids.include?(project.id) %> class="excluded-project-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500 shrink-0">
                  <span class="text-sm text-gray-700 min-w-0"><%= project.title %></span>
                </label>
              </li>
            <% end %>
          <% end %>
        </ul>
        <p id="excluded-project-search-no-results" class="hidden mt-2 text-sm text-gray-500 italic">No projects matched your search.</p>
      </div>

      <div>
        <label for="question" class="block text-sm font-medium text-gray-700 mb-1">Your question</label>
        <textarea id="question" name="question" rows="5" class="w-full rounded-md border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500" placeholder="Example: What patterns do you see in high-priority open tasks?"><%= @question %></textarea>
      </div>

      <div>
        <button type="submit" id="task-insights-submit" class="bg-indigo-600 hover:bg-indigo-800 text-white font-bold py-2 px-4 rounded" <%= "disabled" if @available_ai_models.empty? %>>
          Ask Insights
        </button>
      </div>
    <% end %>
  </div>

  <div id="task-insights-live-status" class="hidden surface shadow-lg rounded-lg p-4 mt-4 border border-indigo-200">
    <h2 class="text-sm font-semibold text-gray-900 mb-1">Agent status</h2>
    <div class="flex items-center gap-2 text-sm text-gray-600">
      <span class="inline-block h-4 w-4 rounded-full border-2 border-indigo-600 border-t-transparent animate-spin" id="task-insights-live-spinner" aria-hidden="true"></span>
      <span id="task-insights-live-status-text">Starting…</span>
    </div>
    <p id="task-insights-live-error" class="hidden mt-2 text-sm text-red-700"></p>
  </div>

  <div id="task-insights-result" class="mt-6 space-y-3">
    <% @messages.each do |message| %>
      <div class="surface shadow-lg rounded-lg p-4 border <%= message.role == 'user' ? 'border-gray-200' : 'border-indigo-200' %>">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1"><%= message.role == "user" ? "You" : "Assistant" %></h3>
        <% if message.role == "user" %>
          <p class="text-sm text-gray-700 whitespace-pre-line"><%= message.content %></p>
        <% else %>
          <div class="text-sm text-gray-700 prose prose-sm max-w-none"><%= markdown_robust(message.content) %></div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<script>
  (function() {
    var form = document.getElementById('task-insights-form');
    var submit = document.getElementById('task-insights-submit');
    var liveBox = document.getElementById('task-insights-live-status');
    var liveText = document.getElementById('task-insights-live-status-text');
    var liveError = document.getElementById('task-insights-live-error');
    var spinner = document.getElementById('task-insights-live-spinner');
    var resultEl = document.getElementById('task-insights-result');
    var excludedSearch = document.getElementById('excluded-project-search');
    var excludedList = document.getElementById('excluded-projects-list');
    var excludedNoResults = document.getElementById('excluded-project-search-no-results');
    var excludedToggleAll = document.getElementById('toggle-all-excluded-projects');
    var pollTimer = null;
    var ollamaHealthTimer = null;
    var ollamaOk = <%= @available_ai_models.any? ? 'true' : 'false' %>;
    var jobRunning = false;

    if (!form || !liveBox || !liveText || !resultEl) return;

    var createUrl = <%= raw task_insights_path.to_json %>;
    var statusUrlTemplate = <%= raw task_insights_status_path(run_id: "__RUN_ID__").to_json %>;
    var ollamaHealthUrl = <%= raw task_insights_ollama_health_path.to_json %>;
    var ollamaMsg = document.getElementById('task-insights-ollama-msg');
    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    csrfToken = csrfToken ? csrfToken.getAttribute('content') : '';

    var STATE_LABELS = {
      received_question: 'Processing your question…',
      requesting_model_step: 'Querying model for next step…',
      model_response_invalid: 'Evaluating model response…',
      attempting_json_repair: 'Repairing invalid model output…',
      model_response_unrecoverable: 'Could not parse model output',
      model_request_failed: 'Model request failed',
      executing_tool: 'Running a tool…',
      tool_result_received: 'Tool finished; continuing…',
      final_answer_ready: 'Composing final answer…',
      fallback_answer: 'Finishing up…',
      final_answer_empty: 'Finishing up…',
      job_exception: 'Error'
    };

    function clearPoll() {
      if (pollTimer) {
        window.clearInterval(pollTimer);
        pollTimer = null;
      }
    }

    function applySubmitAvailability() {
      if (!submit) return;
      var canSubmit = ollamaOk && !jobRunning;
      submit.disabled = !canSubmit;
      submit.classList.toggle('opacity-70', !canSubmit);
      submit.classList.toggle('cursor-not-allowed', !canSubmit);
    }

    function resetSubmitUi() {
      jobRunning = false;
      applySubmitAvailability();
    }

    function refreshModelSelect(models) {
      var sel = document.getElementById('ai_model');
      if (!sel || !models || !models.length) return;
      var prev = sel.value;
      sel.innerHTML = '';
      for (var i = 0; i < models.length; i++) {
        var m = models[i];
        var opt = document.createElement('option');
        opt.value = m;
        opt.textContent = m;
        if (m === prev) opt.selected = true;
        sel.appendChild(opt);
      }
      if (!sel.value && models.length) sel.selectedIndex = 0;
    }

    function updateOllamaBanner() {
      if (!ollamaMsg) return;
      ollamaMsg.classList.toggle('hidden', !!ollamaOk);
    }

    function fetchOllamaHealth() {
      fetch(ollamaHealthUrl, {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      }).then(function(r) {
        return r.ok ? r.json() : Promise.resolve({ ok: false, models: [] });
      }).then(function(data) {
        ollamaOk = !!(data && data.ok);
        if (ollamaOk && data.models && data.models.length) refreshModelSelect(data.models);
        updateOllamaBanner();
        applySubmitAvailability();
      }).catch(function() {
        ollamaOk = false;
        updateOllamaBanner();
        applySubmitAvailability();
      });
    }

    function startOllamaHealthPolling() {
      if (ollamaHealthTimer) window.clearInterval(ollamaHealthTimer);
      ollamaHealthTimer = window.setInterval(fetchOllamaHealth, 12000);
    }

    function setSpinner(active) {
      if (!spinner) return;
      spinner.classList.toggle('hidden', !active);
    }

    function labelForPayload(payload) {
      var events = payload.state_events || [];
      if (!events.length) return 'Waiting for the job to start…';
      var last = events[events.length - 1];
      var key = last.state;
      var modelCalls = events.filter(function(e) { return e.state === 'requesting_model_step'; }).length;
      var toolCalls = events.filter(function(e) { return e.state === 'executing_tool'; }).length;
      if (key === 'requesting_model_step') return 'Querying model for next step (model call ' + modelCalls + ')…';
      if (key === 'executing_tool' && last.tool) {
        var stepNo = (typeof last.tool_step === 'number') ? last.tool_step : toolCalls;
        return 'Running tool #' + stepNo + ': ' + displayToolName(last.tool);
      }
      if (key === 'tool_result_received' && last.tool) {
        var resultStepNo = (typeof last.tool_step === 'number') ? last.tool_step : toolCalls;
        var count = (typeof last.result_count === 'number') ? ('; returned ' + last.result_count + ' item(s)') : '';
        return 'Tool #' + resultStepNo + ' finished: ' + displayToolName(last.tool) + count;
      }
      if (STATE_LABELS[key]) return STATE_LABELS[key];
      return key || 'Working…';
    }

    function esc(s) {
      var d = document.createElement('div');
      d.textContent = s == null ? '' : String(s);
      return d.innerHTML;
    }

    function displayToolName(tool) {
      if (typeof tool === 'string') return tool;
      try {
        return JSON.stringify(tool);
      } catch (_e) {
        return String(tool);
      }
    }

    function applyExcludedProjectFilter() {
      if (!excludedSearch || !excludedList) return;
      var query = excludedSearch.value.trim().toLowerCase();
      var rows = Array.from(excludedList.querySelectorAll('li.excluded-project-row'));
      var visibleCount = 0;
      rows.forEach(function(row) {
        var title = (row.getAttribute('data-project-title') || '').toLowerCase();
        var show = !query || title.indexOf(query) !== -1;
        row.style.display = show ? '' : 'none';
        if (show) visibleCount += 1;
      });
      if (excludedNoResults) excludedNoResults.classList.toggle('hidden', visibleCount > 0 || !query);
    }

    function toggleAllExcludedProjects() {
      if (!excludedList) return;
      var boxes = Array.from(excludedList.querySelectorAll('input.excluded-project-checkbox'));
      var anyUnchecked = boxes.some(function(box) { return !box.checked; });
      boxes.forEach(function(box) { box.checked = anyUnchecked; });
      if (excludedToggleAll) excludedToggleAll.textContent = anyUnchecked ? 'Deselect all' : 'Select all';
    }

    function renderResult(payload) {
      var answer = payload.answer || '';
      var answerHtml = payload.answer_html;
      var tools = payload.tool_calls || [];
      var events = payload.state_events || [];
      var html = '<div class="surface shadow-lg rounded-lg p-6 border border-indigo-200">';
      html += '<h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1">Assistant</h3>';
      if (answerHtml) {
        html += '<div class="text-sm text-gray-700 prose prose-sm max-w-none">' + answerHtml + '</div>';
      } else {
        html += '<p class="text-sm text-gray-700 whitespace-pre-line">' + esc(answer) + '</p>';
      }
      if (tools.length) {
        html += '<div class="mt-4"><h3 class="text-sm font-semibold text-gray-700 mb-1">Tools used</h3><ul class="text-xs text-gray-600 space-y-1">';
        for (var t = 0; t < tools.length; t++) {
          var c = tools[t];
          var args = esc(JSON.stringify(c.arguments || {}));
          var countText = (typeof c.result_count === 'number') ? ' → returned ' + c.result_count + ' item(s)' : '';
          var errorText = c.error ? ' — error: ' + c.error : '';
          var stepPrefix = (typeof c.step === 'number') ? ('#' + c.step + ' ') : '';
          html += '<li>' + esc(stepPrefix) + '<code>' + esc(displayToolName(c.tool)) + '</code> ' + args + esc(countText + errorText) + '</li>';
        }
        html += '</ul></div>';
      }
      if (events.length) {
        html += '<div class="mt-4"><h3 class="text-sm font-semibold text-gray-700 mb-1">Agent state trace</h3><ul class="text-xs text-gray-600 space-y-1">';
        for (var e = 0; e < events.length; e++) {
          var ev = events[e];
          var line = esc(ev.state || '');
          if (ev.tool) line += ' (' + esc(displayToolName(ev.tool)) + ')';
          if (typeof ev.tool_step === 'number') line += ' [#' + esc(ev.tool_step) + ']';
          if (typeof ev.result_count === 'number') line += ' — returned ' + esc(ev.result_count) + ' item(s)';
          if (ev.error) line += ' — error: ' + esc(ev.error);
          if (ev.message) line += ' — ' + esc(ev.message);
          html += '<li>' + line + '</li>';
        }
        html += '</ul></div>';
      }
      html += '</div>';
      resultEl.insertAdjacentHTML('beforeend', html);
    }

    function appendUserMessage(question) {
      var html = '<div class="surface shadow-lg rounded-lg p-4 border border-gray-200">';
      html += '<h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1">You</h3>';
      html += '<p class="text-sm text-gray-700 whitespace-pre-line">' + esc(question) + '</p>';
      html += '</div>';
      resultEl.insertAdjacentHTML('beforeend', html);
    }

    function pollStatus(runId) {
      var url = statusUrlTemplate.replace('__RUN_ID__', encodeURIComponent(runId));
      var attempts = 0;
      var maxAttempts = 900;

      clearPoll();

      function pollOnce() {
        attempts += 1;
        if (attempts > maxAttempts) {
          clearPoll();
          liveError.textContent = 'Timed out waiting for the server. If you use production Solid Queue, ensure a worker is running.';
          liveError.classList.remove('hidden');
          setSpinner(false);
          resetSubmitUi();
          return;
        }

        fetch(url, {
          method: 'GET',
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin'
        }).then(function(r) {
          if (r.status === 404) throw new Error('Run not found or expired.');
          if (!r.ok) throw new Error('Status request failed (' + r.status + ').');
          return r.json();
        }).then(function(payload) {
          liveText.textContent = labelForPayload(payload);
          if (payload.status === 'complete') {
            clearPoll();
            liveBox.classList.add('hidden');
            liveError.classList.add('hidden');
            setSpinner(false);
            resetSubmitUi();
            renderResult(payload);
          } else if (payload.status === 'failed') {
            clearPoll();
            liveText.textContent = 'Failed';
            liveError.textContent = payload.error || 'Something went wrong.';
            liveError.classList.remove('hidden');
            setSpinner(false);
            resetSubmitUi();
            renderResult(payload);
            liveBox.classList.remove('hidden');
          }
        }).catch(function(err) {
          clearPoll();
          liveText.textContent = 'Error';
          liveError.textContent = err.message || String(err);
          liveError.classList.remove('hidden');
          setSpinner(false);
          resetSubmitUi();
        });
      }

      pollOnce();
      pollTimer = window.setInterval(pollOnce, 400);
    }

    form.addEventListener('submit', function(ev) {
      ev.preventDefault();
      clearPoll();

      var question = (document.getElementById('question') || {}).value || '';
      if (!question.trim()) return;
      if (!ollamaOk) return;

      jobRunning = true;
      applySubmitAvailability();

      liveBox.classList.remove('hidden');
      liveError.classList.add('hidden');
      liveError.textContent = '';
      liveText.textContent = 'Sending request…';
      setSpinner(true);
      appendUserMessage(question.trim());

      var aiLocale = (document.getElementById('ai_locale') || {}).value;
      var aiModel = (document.getElementById('ai_model') || {}).value;
      var conversationId = (document.getElementById('conversation_id') || {}).value;
      var excludedProjectIds = [];
      if (excludedList) {
        excludedList.querySelectorAll('input.excluded-project-checkbox:checked').forEach(function(box) {
          excludedProjectIds.push(parseInt(box.value, 10));
        });
      }

      fetch(createUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        credentials: 'same-origin',
        body: JSON.stringify({
          question: question,
          ai_locale: aiLocale,
          ai_model: aiModel,
          conversation_id: conversationId,
          excluded_project_ids: excludedProjectIds
        })
      }).then(function(r) {
        return r.json().then(function(body) {
          return { ok: r.ok, status: r.status, body: body };
        });
      }).then(function(res) {
        if (!res.ok) {
          var msg = (res.body && res.body.error) ? res.body.error : ('Request failed (' + res.status + ')');
          throw new Error(msg);
        }
        if (!res.body.run_id) throw new Error('No run id returned.');
        if (res.body.conversation_id) {
          var conversationInput = document.getElementById('conversation_id');
          if (conversationInput) conversationInput.value = res.body.conversation_id;
        }
        liveText.textContent = 'Run started; waiting for updates…';
        pollStatus(res.body.run_id);
      }).catch(function(err) {
        liveText.textContent = 'Could not start run';
        liveError.textContent = err.message || String(err);
        liveError.classList.remove('hidden');
        setSpinner(false);
        resetSubmitUi();
      });
    });

    window.addEventListener('pageshow', function(ev) {
      clearPoll();
      resetSubmitUi();
      if (ev.persisted) fetchOllamaHealth();
    });

    window.addEventListener('pagehide', clearPoll);

    document.addEventListener('visibilitychange', function() {
      if (document.visibilityState === 'visible') fetchOllamaHealth();
    });

    if (excludedSearch) {
      excludedSearch.addEventListener('input', applyExcludedProjectFilter);
      excludedSearch.addEventListener('change', applyExcludedProjectFilter);
    }
    if (excludedToggleAll) {
      excludedToggleAll.addEventListener('click', toggleAllExcludedProjects);
    }

    applySubmitAvailability();
    fetchOllamaHealth();
    startOllamaHealthPolling();
  })();
</script>
