<div class="container mx-auto px-4 py-8 max-w-3xl">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('views.notifications.index.title') %></h1>
    <% if current_user.notifications.unread.exists? %>
      <%= button_to t('views.notifications.index.mark_all_read'), mark_all_read_notifications_path, method: :patch,
          class: "bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded", data: { turbo: false } %>
    <% end %>
  </div>

  <% if @notifications.empty? %>
    <div class="surface shadow rounded-lg p-6 text-center text-gray-500">
      <%= t('views.notifications.index.no_notifications') %>
    </div>
  <% else %>
    <div class="surface shadow rounded-lg divide-y divide-gray-200">
      <% @notifications.each do |notification| %>
        <div class="p-4 flex items-start justify-between <%= 'bg-blue-50' unless notification.read? %>">
          <div>
            <div class="text-sm font-medium text-gray-900"><%= notification.title %></div>
            <% if notification.body.present? %>
              <div class="mt-1 text-sm text-gray-600"><%= notification.body %></div>
            <% end %>
            <div class="mt-1 text-xs text-gray-400"><%= notification.created_at.strftime("%Y-%m-%d %H:%M") %></div>
            <% if notification.link_path.present? %>
              <%= link_to t('views.notifications.index.view'), notification.link_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
            <% end %>
          </div>
          <% unless notification.read? %>
            <%= button_to t('views.notifications.index.mark_read'), mark_read_notification_path(notification), method: :patch,
                class: "text-sm text-gray-500 hover:text-gray-800 whitespace-nowrap ml-4", data: { turbo: false } %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mt-4">
      <%= paginate @notifications, window: 2, outer_window: 1, views_prefix: 'shared', data: { turbo: false } %>
    </div>
  <% end %>
</div>
